{
  "version": "6.1",
  "name": "byjg/gluo",
  "description": "Gluo — production-ready PHP REST API framework starter. Create a project with `composer create-project byjg/gluo` and focus on your business logic, not the infrastructure.",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "MIT",
  "repositories": [
    {
      "type": "path",
      "url": "../php-arx"
    }
  ],
  "require": {
    "php": ">=8.3 <8.6",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-curl": "*",
    "byjg/gluo-core": "dev-master",
    "byjg/scriptify": "^6.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.8",
    "vimeo/psalm": "^6.13"
  },
  "autoload": {
    "psr-4": {
      "RestReferenceArchitecture\\": "src/",
      "Builder\\": "builder/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/phpunit",
    "migrate": "Builder\\Scripts::migrate",
    "codegen": "Builder\\Scripts::codeGenerator",
    "openapi": "Builder\\Scripts::genOpenApiDocs",
    "terminal": "./vendor/bin/scriptify terminal --preload ./templates/scriptify/scriptify.php --env APP_ENV=$APP_ENV",
    "compile": "git pull && composer run openapi && composer run test",
    "up-local-dev": "docker compose -f docker-compose.yml up -d",
    "down-local-dev": "docker compose -f docker-compose.yml down",
    "post-create-project-cmd": "Builder\\PostCreateScript::run",
    "psalm": "vendor/bin/psalm"
  },
  "autoload-dev": {
    "psr-4": {
      "Test\\": "tests/"
    }
  }
}
