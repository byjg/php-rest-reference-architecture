{
  "version": "7.0",
  "name": "byjg/gluo",
  "description": "Gluo — full-stack-capable PHP REST API starter. Run `composer create-project byjg/gluo` and focus on your business logic, not the infrastructure.",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "MIT",
  "require": {
    "php": ">=8.3 <8.6"
  },
  "autoload": {
    "psr-4": {
      "Builder\\": "api/builder/"
    }
  },
  "scripts": {
    "post-create-project-cmd": "Builder\\PostCreateScript::run",
    "test": "@php -r \"exit((int) passthru('composer --working-dir=api test '.implode(' ', array_slice($argv, 1))));\"",
    "migrate": "@php -r \"exit((int) passthru('composer --working-dir=api migrate '.implode(' ', array_slice($argv, 1))));\"",
    "codegen": "@php -r \"exit((int) passthru('composer --working-dir=api codegen '.implode(' ', array_slice($argv, 1))));\"",
    "openapi": "@php -r \"exit((int) passthru('composer --working-dir=api openapi '.implode(' ', array_slice($argv, 1))));\"",
    "psalm": "@php -r \"exit((int) passthru('composer --working-dir=api psalm '.implode(' ', array_slice($argv, 1))));\"",
    "terminal": "@php -r \"exit((int) passthru('composer --working-dir=api terminal '.implode(' ', array_slice($argv, 1))));\"",
    "up-local-dev": "docker compose -f docker-compose.yml up -d",
    "down-local-dev": "docker compose -f docker-compose.yml down"
  }
}
