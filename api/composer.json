{
  "version": "7.0",
  "name": "byjg/gluo-api",
  "description": "Gluo — the PHP REST API of a Gluo project (the `api/` half of the starter).",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "MIT",
  "require": {
    "php": ">=8.3 <8.6",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-curl": "*",
    "byjg/gluo-core": "^7.0",
    "byjg/scriptify": "^6.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.8",
    "vimeo/psalm": "^6.13"
  },
  "autoload": {
    "psr-4": {
      "RestReferenceArchitecture\\": "src/",
      "Builder\\": "builder/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/phpunit",
    "migrate": "Builder\\Scripts::migrate",
    "codegen": "Builder\\Scripts::codeGenerator",
    "openapi": "Builder\\Scripts::genOpenApiDocs",
    "terminal": "./vendor/bin/scriptify terminal --preload ./templates/scriptify/scriptify.php --env APP_ENV=$APP_ENV",
    "compile": "git pull && composer run openapi && composer run test",
    "psalm": "vendor/bin/psalm"
  },
  "autoload-dev": {
    "psr-4": {
      "Test\\": "tests/"
    }
  }
}
