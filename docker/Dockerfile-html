# Build the Vite app and serve the static output with byjg/static-httpserver.
FROM node:22-alpine AS builder
WORKDIR /app
COPY html/package.json html/package-lock.json* ./
RUN npm install
COPY html/ ./
RUN npm run build

FROM byjg/static-httpserver
ENV SPA_MODE=true
ENV ROOT_DIR=/static
ENV PORT=8080
COPY --from=builder /app/dist /static
