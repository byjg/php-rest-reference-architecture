# Base URL of the Gluo API, baked into the bundle at BUILD time.
# Used by `npm run dev` and a plain `npm run build`. In local docker compose the
# API is on :8080.
#
# For the Docker image (docker/Dockerfile-html) the API URL is instead set at
# RUNTIME via the API_BASE_URL environment variable, which the entrypoint writes
# into /config.js — so one built image can target any API host without rebuilding.
VITE_API_BASE_URL=http://localhost:8080
